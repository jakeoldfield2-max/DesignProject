<Group view="code" hide-input="false" labelreference="L136" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Equations
R := (T__hot1 - T__hot2)/(T__cold2 - T__cold1);
R__gas := 8.314;
S := (T__cold2 - T__cold1)/(T__hot1 - T__cold1);
A__req := Q/(F*U*DeltaT__LM);
DeltaT__LM := ((T__hot2 - T__cold1)-(T__hot1 - T__cold2))/ln((T__hot2-T__cold1)/(T__hot1-T__cold2));
T__hot2 := T__hot1 - Q/(m__hot*c__hot); #Outlet temperature of hot fluid

</Text-field>
</Input>
