<Group view="code" hide-input="false" labelreference="L16" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Assumes no added pressure from coiling up and down sides, gravity pressure is negligable.
# Laminar friction factor for straight duct
f__1 := 16/Re__1;  # Fanning friction factor, laminar
DP__1 := 4*f__1*(L__path1/D__h)*(rho*v^2/2);

f__2 := 16/Re__2;
DP__2 := 4*f__2*(L__path2/D__h)*(rho*v^2/2);

DP__total := DP__1 + DP__2;
</Text-field>
</Input>
