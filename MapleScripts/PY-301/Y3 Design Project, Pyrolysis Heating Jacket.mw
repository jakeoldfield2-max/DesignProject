<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#1 is in
#2 is out
#Hot is oil/salt/water
#Cold is the wall


print(&quot;====Specifications====&quot;);
T__hot1 := 605.5797078 + 273.15; #Kelvin (Defined in Furnace Specs)(Assumes no loss of energy in pipes)
m := 0.7609; #kg/s (From Furnace)

D__pyrolizer := 0.318; #m
D__jacket := 0.348; #m
L__1 := 2.05;  #m # heating zone
L__2 := 2.57;  #m # constant temp zone
Q__1 := 23550; #W # Required energy for pyrolizer heating zone
Q__2 := 20070; #W # Energy needed to maintain temperature

T__cold_in := 280 + 273.15;  #K, wall at biomass inlet
T__cold_out := 550 + 273.15; #K, wall at end of L1 / all of L2<Font opaque="true" background="[255,255,0]">
</Font>

