<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ====V erification of q__rad ====

q__rad_check := Q__R_final / A__rad_actual;   # W/m2
q__rad_check_Btu := q__rad_check * 0.316998;  # W/m2 -&gt; Btu/hr/ft2
 
<Font encoding="UTF-8">printf((&quot;Actual radiant flux: %.0f W/m2 (%.0f Btu/hr/ft2)\134n&quot;, q__rad_check), q__rad_check_Btu);
printf(&quot;Target was: %.0f W/m2\134n&quot;, q__rad);
</Font> 
if abs(q__rad_check - q__rad)/q__rad &gt; 0.10 then
<Font encoding="UTF-8">    printf(&quot;  STATUS: &gt;10%% deviation -- adjust coil geometry and re-run\134n&quot;);
</Font>else
<Font encoding="UTF-8">    printf(&quot;  STATUS: PASS (within 10%% of target)\134n&quot;);
</Font>end if;

</Text-field>
</Input>
