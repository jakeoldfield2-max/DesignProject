<Section collapsed="false" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">==== Oil  Burner ====</Text-field></Title><Presentation-Block>
<Group view="code" labelreference="L380" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Citation: Lacava, Bastos-Netto &amp; Pimenta (2004)
# &quot;Design Procedure and Experimental Evaluation of 
#  Pressure-Swirl Atomizers&quot;
# 24th International Congress of the Aeronautical Sciences
</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L379" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">FN__oil := m__oil/(rho__oil * DP__oil)^(1/2); #m2 
  
</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SShGTl9fb2lsR0YoJCIreUZMMTUhIzs3I0Yu</Equation></Text-field>
</Output>
</Group>
<Group view="code" labelreference="L378" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Image height="255" width="567" zoomable="false" labelreference="L4" drawcaption="false" captionalignment="0" captionposition="1" bookmark=""><Drawing-Root>LSUrQU5OT1RBVElPTkc2Jy0lKUJPVU5EU19YRzYjLCQtJSZGbG9hdEc2IyUpaW5maW5pdHlHISIiLSUpQk9VTkRTX1lHRictJS1CT1VORFNfV0lEVEhHRictJS5CT1VORFNfSEVJR0hUR0YnLSUpQ0hJTERSRU5HNiI=</Drawing-Root></Image>
</Text-field>
</Input>
</Group>
<Group view="code" labelreference="L377" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Nozzle dimensions calculations
</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L376" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">A__0 := 3.14*(D__0/2)^2; #m2 (Cross section area of nozzle)
Cd__oil := simplify(m__oil/(A__0 * (2*rho__oil*DP__oil)^(1/2))); #m2 (Discharge coefficient)
A__p_oil := n__p_oil * 3.14*(D__p/2)^2;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSVBX18wR0YoJCIrKytEbTwhIzo3I0Yu</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SShDZF9fb2lsR0YoJCIrJ0cpeUdTISM2NyNGLg==</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSlBX19wX29pbEdGKCQiKysrU0k2ISM6NyNGLg==</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L375" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Calculating nozzle sizing ratios and their acceptance

eq1__Carlisle_oil := Cd__oil = 0.0616*(D__s/D__0)*(A__p_oil/(D__s*D__0));
eq2__RL_oil := Cd__oil = 0.35*(D__s/D__0)^0.5*(A__p_oil/(D__s*D__0))^0.5;
eq3__Jones_oil := Cd__oil = 0.45*((D__0*rho__oil*U__0_oil)/mu__oil)^(-0.02)*(L__0/D__0)^(-0.03)*(L__s/D__s)^0.05*(A__p_oil/(D__s*D__0))^0.52*(D__s/D__0)^0.23;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+STJlcTFfX0Nhcmxpc2xlX29pbEdGKC8kIisnRyl5R1MhIzYkIisrU3klNCRGMTcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSxlcTJfX1JMX29pbEdGKC8kIisnRyl5R1MhIzYkIis/aiEzWyMhIzU3I0Yu</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SS9lcTNfX0pvbmVzX29pbEdGKC8kIisnRyl5R1MhIzYsJCokSSlVX18wX29pbEdGKCQhIiNGNiQiKz4rPyRSIyEjNTcjRi4=</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L374" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Acceptance based on spray semi angle

K__oil := A__p_oil/(D__s*D__0);
eqX := D__0 = 2*((FN__oil)/(3.14*(1-X__oil)*(2)^(1/2)))^(1/2);
X__oil := solve(eqX,X__oil);
eq3__oil := sin(theta__oil) = ((3.14/2)*Cd__oil)/(K__oil*(1+(X__oil)^(1/2)));
theta__oil := simplify(solve(eq3__oil,theta__oil));</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSdLX19vaWxHRigkIisrKys3RCEjNTcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSRlcVhHRigvJCIjOiEiJSwkKiQqJiwmIiIiRjZJJ1hfX29pbEdGKCEiIkY4IiIjI0Y2RjlGOiQiK2Y0dkpEISM4NyNGLg==</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSdYX19vaWxHRigkIityNjcoZiohIzU3I0Yu</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSllcTNfX29pbEdGKC8tSSRzaW5HRiU2I0krdGhldGFfX29pbEdGKCQiK3EqUT5GIiEjNTcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSt0aGV0YV9fb2lsR0YoJCIrOVFSdjchIzU3I0Yu</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L373" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Liquid Sheet Thickness at Nozzle tip

h__0_oil := simplify((0.00805*FN__oil*(rho__oil)^(1/2))/(D__0*cos(theta__oil)));</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSloX18wX29pbEdGKCQiK3AwOycpPSEjOTcjRi4=</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L372" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Calculating the ligament diameter

U__0_oil := simplify((2*DP__oil/rho__oil)^(1/2));
D__L_oil := simplify( 0.9615*cos(theta__oil)*((h__0_oil^4*sigma__oil^2)/(U__0_oil^4*rho__a*rho__oil))^(1/6)*(1+2.6*mu__oil*cos(theta__oil)*((h__0_oil^2*rho__a^4*U__0_oil^7)/(72*rho__oil^2*sigma__oil^5)^(1/3)))^0.2);
</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSlVX18wX29pbEdGKCQiKy9IWyMzJSEiKTcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSlEX19MX29pbEdGKCQiKzglND5nJyEjOjcjRi4=</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L371" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Mean Diameter Size
#If the atomizer correctly forms droplets, then droplet diameter is:

SMD_oil := 1.89*D__L_oil;</Text-field>
</Input>
