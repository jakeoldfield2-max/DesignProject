<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#LMTD calculation In Farenheight
DT__conv_hot := T__g - T__salt_rad_in_F;
DT__conv_cold := T__stack - T__salt_in_F;
 
if DT__conv_cold &lt;= 0 then
<Font encoding="UTF-8">    printf(&quot;  WARNING: Stack temp below salt inlet -- check efficiency target\134n&quot;);
</Font>    LMTD__conv_F := DT__conv_hot;  # fallback
elif abs(DT__conv_hot - DT__conv_cold) &lt; 1 then
    LMTD__conv_F := (DT__conv_hot + DT__conv_cold)/2;
else
    LMTD__conv_F :=(DT__conv_hot - DT__conv_cold)/ln(DT__conv_hot/DT__conv_cold);
end if;</Text-field>
</Input>
