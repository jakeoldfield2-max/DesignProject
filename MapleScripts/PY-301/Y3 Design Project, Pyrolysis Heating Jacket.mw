<Group view="code" hide-input="false" labelreference="L105" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ===== Spiral Baffle Channel Calculations =====
Pitch := 0.07; # m
t__baffle := 0.005; # m
w__ch := Pitch - t__baffle; # m
GAP := (D__jacket - D__pyrolizer)/2; # m

# Flow Area and Wetted Perimeter
Ac := w__ch * GAP; 
P__w := 2*w__ch + 2*GAP; 

# Hydraulic diameter &amp; Velocity
D__h := 4*Ac/P__w;
v := m/(rho*Ac);

# Flow Path Lengths
L__path1 := L__1 *(Pi * D__pyrolizer/Pitch);
L__path2 := L__2 *(Pi * D__pyrolizer/Pitch);</Text-field>
</Input>
