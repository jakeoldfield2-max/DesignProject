<Group view="code" hide-input="false" labelreference="L161" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">eq1 := V__fuel = 0.0467*C__d_gas * A__o*((p__prior_gas*10.197)/s)^(1/2); </Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSRlcTFHRigvSShWX19mdWVsR0YoLCQqKEklQV9fb0dGKCIiIiIjSSNGMyIiIyokSSJzR0YoISIiRjUkIitSSjhVOCEjNTcjRi4=</Equation></Text-field>
</Output>
</Group>
<Group view="code" hide-input="false" labelreference="L160" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Variables
biogas := sprintf(&quot;CH4[%f]&amp;CO2[%f]&quot;, xi__CH4, xi__CO2); #mixture of biogas
#For C__d_gas, we must follow design optimization rules to make this value valid. 
rho__mix := CoolProp:-PropsSI(&quot;D&quot;,&quot;P&quot;,101325+(p__prior_gas*100), &quot;T&quot;, T__prior_gas,biogas); #kg/m3
m__fuel_kg_h := (m__fuel_gas * 3600);
V__fuel := m__fuel_kg_h / rho__mix; #m3/h
