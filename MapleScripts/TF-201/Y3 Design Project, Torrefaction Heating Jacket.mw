<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#helical cannels (If pressure is too high, consider splitting channels into two, but will half velocity and Re.)
w := 0.062; #m #Channel width
t := 0.330; #m #Wall thickness
P := w + t; #m #pitch

N__turn := L/P; #number of turns
L__turn := ((Pi*D__coil)**2 + P**2)**(1/2); #m #Length per turn
L__coil := N__turn * L__turn; #m
GAP := (D__jacket - D__pyrolizer)/2;
A__c := GAP*w;
D__h := 2*GAP*w/(GAP +w);
D__coil := (D__jacket + D__pyrolizer)/2;</Text-field>
</Input>
