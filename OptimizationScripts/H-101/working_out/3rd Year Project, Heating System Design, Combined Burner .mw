<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">z__Uc := T__f_conv_F / 1000;

a__Uc := 2.461 - 0.759*z__Uc + 1.625*z__Uc^2;
b__Uc := 0.7655 + 21.373*z__Uc - 9.6625*z__Uc^2;
c__Uc := 9.7938 - 30.809*z__Uc + 14.333*z__Uc^2;
 
U__convection_Btu := simplify((a__Uc + b__Uc*G__convection + c__Uc*G__convection^2)*(4.5/d__tube_OD_conv)^0.25); #Btu/hr/ft2/F
U__convection := U__convection_Btu * 5.67826;   #  W/m2/K</Text-field>
</Input>
