<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#helical cannels (If pressure is too high, consider splitting channels into two, but will half velocity and Re.)
w := 0.065; #m #Channel width
t := 0.018; #m #Wall thickness
P := w + t; #m #pitch

N__turn := L__jacket/P; #number of turns
L__turn := ((Pi*D__separator)**2 + P**2)**(1/2); #m #Length per turn
L__coil := N__turn * L__turn; #m
A__c := GAP*w;
D__h := 2*GAP*w/(GAP +w);
D__coil := (D__jacket + D__separator)/2;</Text-field>
