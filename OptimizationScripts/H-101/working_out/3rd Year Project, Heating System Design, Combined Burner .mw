<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#=== Thermo Dynamic reset for different temperatures ===

T__salt_avg_conv := (T__salt_in + T__salt_rad_in_C)/2;
T__salt_avg_conv_K := T__salt_avg_conv + 273.15;

mu__salt_conv_Pas := F_mu__salt(T__salt_avg_conv_K)/ 1000;
v__salt_conv := (m__salt / (rho__salt * Pi * (d__tube_ID_heat/2)^2))/n__conv_parallel; #calculates if streams are in parallel
Re__salt_conv := (rho__salt * v__salt_conv * d__tube_ID_heat)/mu__salt_conv_Pas;
Pr__salt_conv := Cp__salt * mu__salt_conv_Pas / k__salt;
</Text-field>
