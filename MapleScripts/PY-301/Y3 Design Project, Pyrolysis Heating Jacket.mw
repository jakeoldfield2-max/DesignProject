<Group view="code" hide-input="false" labelreference="L91" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Section 1: co-current, wall heated up
dT1__in := T__hot1 - T__cold_in; 
dT1__out := T__hot_mid - T__cold_out;  
LMTD__1 := (dT1__in - dT1__out)/ln(dT1__in/dT1__out);

# Section 2: wall constant
dT2__in := T__hot_mid - T__cold_out;
dT2__out := T__hot2 - T__cold_out;
LMTD__2 := (dT2__in - dT2__out)/ln(dT2__in/dT2__out);



# Area without baffle fins
A__bare1 := Pi * D__pyrolizer * L__1;
A__bare2 := Pi * D__pyrolizer * L__2;

#Area of the baffle fin
A__baffle1 := 2 * GAP * L__path1;
A__baffle2 := 2 * GAP * L__path2;

# Required Area vs Available Area
A__av1 := A__bare1 + A__baffle1;
A__req1 := Q__1/(h__1 * LMTD__1);

A__av2 := A__bare2 + A__baffle2;
A__req2 := Q__2/(h__2 * LMTD__2);




# Check if design is valid
if A__av1 &gt; A__req1 and A__av2 &gt; A__req2 then 
    print(&quot;Design Successful&quot;);
else 
    print(&quot;Design Failed&quot;);
end if;</Text-field>
</Input>
