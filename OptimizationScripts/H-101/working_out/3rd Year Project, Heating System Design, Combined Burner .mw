<Group view="code" labelreference="L490" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ==== Exploring salt side thermodynamics with designed geometry ====
</Text-field>
</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L491" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">T__g_K := T__g_C + 273.15;
T__salt_avg_K := (T__salt_in + T__salt_out)/2 + 273.15;
mu__salt_Pas := F_mu__salt(T__salt_avg_K) / 1000;
v__salt := m__salt / (rho__salt * Pi * (d__tube_ID_heat/2)^2);  # m/s
Re__salt := rho__salt * v__salt * d__tube_ID_heat / mu__salt_Pas;
Pr__salt := Cp__salt * mu__salt_Pas / k__salt;
De__salt := Re__salt * sqrt(d__tube_ID_heat / D__coil_heat);</Text-field>
</Input>
