<Group view="code" hide-input="false" labelreference="L302" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">print(&quot;==== Salt Properties ====&quot;);
# Citations:
# https://www.sciencedirect.com/science/article/pii/S0040603124000029#:~:text=long%2Dterm%20application.-,Abstract,heating%20and%20heating%2Dcooling%20cycles.
# https://pubs.rsc.org/en/content/articlehtml/2016/fd/c5fd00236b
# The best ratio of the mixture is a mass ratio with 30% Na2CO3, 33% Li2CO3, 37% K2CO3.
# All values for this mixture can be found in the above reports.

T__salt_melt := 395.68;            # C
T__salt_max := 650;                # C
Cp__salt := 2300;                  # J/kg/K   (Specific Heat)
rho__salt := 2050;                 # kg/m3    (Viscosity)
k__salt := 0.55;                   # W/m/K)
R__gas := 8.314;                   # J/mol/K
<Font encoding="UTF-8">F_mu__salt := T_K -&gt; 0.0852*exp((3.51e4)/(R__gas*T_K));  # mPa\302\267s</Font>

