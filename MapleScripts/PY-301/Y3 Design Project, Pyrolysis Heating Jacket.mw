<Group view="code" hide-input="false" labelreference="L92" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Size CHECK
#cooling, Page 491, fundametals of heat and mass transfer. Uses Sieder-Tate correlation

# For Section 1
Re__1 := rho*v*D__h/F_mu__salt(T__hot_avg1);
Pr__1 := Cp*F_mu__salt(T__hot_avg1)/k__fluid;
Gz__1 := Re__1*Pr__1*D__h/L__path1;
Nu__1 := 1.86*Gz__1^(1/3) * (F_mu__salt(T__hot_avg1)/F_mu__salt(T__cold_out))^0.14;
h__1  := Nu__1*k__fluid/D__h; #(Book uses U)

# For Section 2
Re__2 := rho*v*D__h/F_mu__salt(T__hot_avg2);
Pr__2 := Cp*F_mu__salt(T__hot_avg2)/k__fluid;
Gz__2 := Re__2*Pr__2*D__h/L__path2;
Nu__2 := 1.86*Gz__2^(1/3) * (F_mu__salt(T__hot_avg2)/F_mu__salt(T__cold_out))^0.14;
h__2  := Nu__2*k__fluid/D__h; #(Book uses U)
</Text-field>
</Input>
