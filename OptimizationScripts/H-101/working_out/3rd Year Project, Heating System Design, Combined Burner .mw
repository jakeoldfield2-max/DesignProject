<Group view="code" hide-input="false" labelreference="L503" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ==== Calculating coil Geometry ====

print(&quot;====Turn calculations====&quot;);
A__radiant := Q__radiant/q__rad; #m2 (Required surface area)
L__turn_heat := sqrt((Pi*D__coil_heat)^2 + p__coil_heat^2); #m
A__per_turn := Pi * d__tube_OD_heat * L__turn_heat; #m2
N__turns_heat := A__radiant / A__per_turn;
N__turns_int_heat := ceil(N__turns_heat);
H__coil := N__turns_int_heat * p__coil_heat; #m (total hight of heater column)</Text-field>
</Input>
